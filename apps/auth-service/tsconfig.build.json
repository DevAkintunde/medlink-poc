{
	"compilerOptions": {
		"outDir": "dist",
		//"baseUrl": "dist",
		"paths": {
			"greybox": ["./lib/box/index.js"],
			"greybox/server": ["./lib/box/server/index.js"],
			"greybox/client": ["./lib/box/client/index.js"],
			"greybox/config": ["./lib/box/box.config.js"],
			"@client/*": ["client/*"],
			"@server/*": ["server/*"]
		},
		"declaration": true,
		"emitDeclarationOnly": true,
		"noEmit": false,
		"allowSyntheticDefaultImports": true,
		"moduleResolution": "node",
		"module": "ESNext",

		"lib": ["DOM", "DOM.Iterable", "ESNext"],
		"forceConsistentCasingInFileNames": true,
		"resolveJsonModule": true,
		"jsxImportSource": "react",
		"jsx": "react-jsx"
	},
	"include": ["lib/**/*.ts", "lib/**/*.tsx"],
	"exclude": ["node_modules","test"]
}
