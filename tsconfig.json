{
	"compilerOptions": {
		"target": "ES2022",
		"module": "ESNext",
		"moduleResolution": "bundler", // ← Change from NodeNext
		"esModuleInterop": true,
		"allowSyntheticDefaultImports": true,
		"skipLibCheck": true,
		"strict": true,
		"resolveJsonModule": true,
		"paths": {
			"@medlink/common": ["./common/index.ts"],
			"@medlink/common/*": ["./common/src/*"],
			"@medlink/common/config": ["./common/platform.config.ts"]
		}
	},
	"include": ["./common/types"],
	"files": [],
	"references": [{ "path": "./common" }, { "path": "./apps/auth-service" }]
}
